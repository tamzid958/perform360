// ─────────────────────────────────────────────────────────
// Performs360 — 360 Performance Evaluation SaaS Platform
// Prisma Schema
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// NextAuth.js Models (Auth.js v5 Adapter Compatibility)
// ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthUser {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  @@map("auth_users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────
// GLOBAL (SaaS Owner)
// ─────────────────────────────────────────────────────────

model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
}

model EvaluationTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  sections    Json // Array of { title, questions: [{ text, type, options?, required }] }
  isGlobal    Boolean  @default(false)
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cycleTeams CycleTeam[]
}

// ─────────────────────────────────────────────────────────
// COMPANY / TENANT
// ─────────────────────────────────────────────────────────

model Company {
  id   String  @id @default(cuid())
  name String
  slug String  @unique
  logo String?

  settings Json?

  // Encryption (company-owned, SaaS owner cannot access)
  encryptionKeyEncrypted String
  encryptionSalt         String? // base64-encoded salt for scrypt key derivation
  encryptionSetupAt      DateTime? // null = setup not complete, timestamp = setup done
  keyVersion             Int       @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users         User[]
  teams         Team[]
  cycles        EvaluationCycle[]
  templates     EvaluationTemplate[]
  recoveryCodes RecoveryCode[]
  auditLogs     AuditLog[]
}

enum UserRole {
  ADMIN
  HR
  EMPLOYEE
  EXTERNAL
}

model User {
  id            String    @id @default(cuid())
  email         String
  name          String
  avatar        String?
  role          UserRole  @default(EMPLOYEE)
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  authUserId    String?   // Links to AuthUser for NextAuth session resolution
  createdAt     DateTime  @default(now())
  archivedAt    DateTime? // null = active, set = archived (soft delete)

  // Relations
  teamMemberships  TeamMember[]
  submittedReviews EvaluationResponse[]
  receivedReviews  EvaluationResponse[] @relation("ReviewSubject")

  @@unique([email, companyId])
  @@index([authUserId])
}

// ─────────────────────────────────────────────────────────
// TEAMS
// ─────────────────────────────────────────────────────────

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  archivedAt  DateTime?

  members    TeamMember[]
  cycleTeams CycleTeam[]
}

enum TeamMemberRole {
  MANAGER
  MEMBER
  EXTERNAL
}

model TeamMember {
  id     String         @id @default(cuid())
  userId String
  teamId String
  role   TeamMemberRole

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
}

// ─────────────────────────────────────────────────────────
// EVALUATION CYCLES
// ─────────────────────────────────────────────────────────

enum CycleStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

model EvaluationCycle {
  id        String      @id @default(cuid())
  name      String
  companyId String
  company   Company     @relation(fields: [companyId], references: [id])
  status    CycleStatus @default(DRAFT)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Cached data key (encrypted with NEXTAUTH_SECRET) — set on activation,
  // allows submission route to encrypt reviewer answers without the passphrase.
  cachedDataKeyEncrypted String?

  assignments EvaluationAssignment[]
  cycleTeams  CycleTeam[]
}

model CycleTeam {
  id         String             @id @default(cuid())
  cycleId    String
  cycle      EvaluationCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  teamId     String
  team       Team               @relation(fields: [teamId], references: [id])
  templateId String
  template   EvaluationTemplate @relation(fields: [templateId], references: [id])
  createdAt  DateTime           @default(now())

  @@unique([cycleId, teamId])
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
}

model EvaluationAssignment {
  id           String           @id @default(cuid())
  cycleId      String
  cycle        EvaluationCycle  @relation(fields: [cycleId], references: [id])
  templateId   String
  subjectId    String
  reviewerId   String
  relationship String
  status       AssignmentStatus @default(PENDING)
  token        String           @unique @default(cuid())
  createdAt    DateTime         @default(now())

  responses   EvaluationResponse[]
  otpSessions OtpSession[]

  @@unique([cycleId, subjectId, reviewerId, templateId])
}

// ─────────────────────────────────────────────────────────
// OTP AUTHENTICATION
// ─────────────────────────────────────────────────────────

model OtpSession {
  id            String               @id @default(cuid())
  assignmentId  String
  assignment    EvaluationAssignment @relation(fields: [assignmentId], references: [id])
  email         String
  otpHash       String
  attempts      Int                  @default(0)
  expiresAt     DateTime
  cooldownUntil DateTime?
  verifiedAt    DateTime?
  sessionToken  String?              @unique
  sessionExpiry DateTime?
  createdAt     DateTime             @default(now())
}

// ─────────────────────────────────────────────────────────
// EVALUATION RESPONSES (Encrypted)
// ─────────────────────────────────────────────────────────

model EvaluationResponse {
  id           String               @id @default(cuid())
  assignmentId String
  assignment   EvaluationAssignment @relation(fields: [assignmentId], references: [id])
  reviewerId   String
  reviewer     User                 @relation(fields: [reviewerId], references: [id])
  subjectId    String
  subject      User                 @relation("ReviewSubject", fields: [subjectId], references: [id])

  // Encrypted data (AES-256-GCM)
  answersEncrypted String
  answersIv        String
  answersTag       String
  keyVersion       Int

  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─────────────────────────────────────────────────────────
// RECOVERY CODES (Encryption Key Recovery)
// ─────────────────────────────────────────────────────────

model RecoveryCode {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])
  codeHash         String // bcrypt hash of the recovery code
  encryptedDataKey String // data key encrypted with scrypt(code, salt)
  usedAt           DateTime? // null = available, timestamp = consumed
  createdAt        DateTime  @default(now())

  @@index([companyId])
}

// ─────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String? // null for system events
  action    String // e.g., "decryption", "role_change", "user_invite", "cycle_activate"
  target    String? // e.g., "user:cuid123", "cycle:cuid456"
  metadata  Json? // Additional context
  ip        String?
  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────
// JOB QUEUE (Postgres-backed async task processing)
// ─────────────────────────────────────────────────────────

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  DEAD
}

model JobQueue {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  status      JobStatus @default(PENDING)
  priority    Int       @default(0)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lastError   String?
  runAt       DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt, priority])
  @@index([type, status])
  @@index([createdAt])
}
